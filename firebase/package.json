{
  "name": "@assetanchor/firebase",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "test:rules": "firebase --config ../firebase.json emulators:exec --only firestore \"jest\"",
    "emulators": "firebase --config ../firebase.json emulators:start --only auth,firestore --project assetanchor-832df --import=../.emulator-data --export-on-exit=../.emulator-data",
    "seed:emulator": "FIRESTORE_EMULATOR_HOST=localhost:8080 FIREBASE_AUTH_EMULATOR_HOST=localhost:9099 node scripts/seed-emulator.mjs"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/jest": "^29.5.13",
    "@types/node": "^22.7.5",
    "firebase": "12.10.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.9.3"
  }
}
